{
  "title": "KanzPay Output Dataset",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "sourceUrl": { "type": "string" },
    "sourceType": { "type": "string" },
    "bankName": { "type": "string" },
    "cardName": { "type": "string" },
    "merchantName": { "type": "string" },
    "offerTitle": { "type": "string" },
    "offerDescription": { "type": "string" },
    "discountType": { "type": "string" },
    "discountValue": { "type": "number" },
    "currency": { "type": "string" },
    "minSpend": { "type": "number" },
    "capValue": { "type": "number" },
    "validFrom": { "type": "string", "format": "date" },
    "validTo": { "type": "string", "format": "date" },
    "couponCode": { "type": "string" },
    "paymentMethods": { "type": "array", "items": { "type": "string" } },
    "eligibleMccList": { "type": "array", "items": { "type": "string" } },
    "categories": { "type": "array", "items": { "type": "string" } },
    "stackable": { "type": "boolean" },
    "termsUrl": { "type": "string" },
    "confidence": { "type": "number" },
    "parserName": { "type": "string" },
    "parserReason": { "type": "string" },
    "crawlDepth": { "type": "integer" },
    "pageLength": { "type": "integer" },
    "scrapedAt": { "type": "string", "format": "date-time" },
