PORT=5436
DATABASE_URL=postgresql://kanzpay:kanzpay@localhost:5435/kanzpay

# Production Supabase — KanzPay App DB (seller_profiles, seller_stores, auto-gold)
# Get from: Supabase Dashboard → Project lxrmryqduielvbyypeiy → Settings → Database → Connection string
KANZPAY_APP_DB_URL=postgresql://postgres:[PASSWORD]@db.lxrmryqduielvbyypeiy.supabase.co:5432/postgres

# Production Supabase — Users DB (payment_requests, payment_sessions, user_payment_methods)
# Get from: Supabase Dashboard → Project ariegrjlfenlzelwjsb → Settings → Database → Connection string
SUPABASE_USERS_DB_URL=postgresql://postgres:[PASSWORD]@db.ariegorjlfenlzelwjsb.supabase.co:5432/postgres

# Production Supabase — SafeGold DB (sg_transactions, sg_users)
# Same project (ariegorjlfenlzelwjsb), schema: safegold
SUPABASE_SAFEGOLD_DB_URL=postgresql://postgres:[PASSWORD]@db.ariegorjlfenlzelwjsb.supabase.co:5432/postgres
CRAWL_DATA_DIR=../storage/datasets/default
DISCOVERY_DATA_PATH=../storage/key_value_stores/default/DISCOVERY_RESULTS.json
RUN_SUMMARY_PATH=../storage/key_value_stores/default/RUN_SUMMARY.json
APIFY_TOKEN=
APIFY_WEBHOOK_SECRET=
CONFIDENCE_FLOOR=0.4
STALE_AFTER_DAYS=14
LOG_LEVEL=info

# OpenAI — required for AI-powered payment recommendations
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
OPENAI_ENRICHMENT_MODEL=gpt-4o-mini

# LLM offer enrichment (async batch, off by default)
ENRICHMENT_ENABLED=false
ENRICHMENT_BATCH_SIZE=100
ENRICHMENT_MIN_CONFIDENCE_AUTO=0.85
ENRICHMENT_VERIFY_THRESHOLD=0.65
ENRICHMENT_MAX_RETRIES=3
AUDIT_LLM_SAMPLE_SIZE=50

# Checkout eligibility LLM review (default on when OPENAI_API_KEY is set)
ELIGIBILITY_LLM_REVIEW_ENABLED=true
